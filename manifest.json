{
  "manifest_version": 3,
  "name": "Duplicate Tab Remover",
  "version": "1.0.0",
  "description": "Remove duplicate tabs by comparing URLs. Supports exact match, without query parameters, or without fragments.",
  "author": "Your Name",
  
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  
  "permissions": [
    "tabs",
    "storage",
    "windows"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_title": "Remove Duplicate Tabs"
  },
  
  "commands": {
    "remove-duplicates": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "windows": "Ctrl+Shift+D"
      },
      "description": "Remove duplicate tabs by URL"
    }
  }
}
